#!/command/with-contenv bashio

bashio::log.info "Starting Storage API on port 8100..."

# Read config
GEMINI_API_KEY=$(bashio::config 'gemini_api_key')
GEMINI_MODEL=$(bashio::config 'gemini_model')
DEBUG=$(bashio::config 'debug')

AI_PROVIDER="gemini"
if bashio::config.has_value 'ai_provider'; then
    AI_PROVIDER=$(bashio::config 'ai_provider')
fi

OLLAMA_URL=""
if bashio::config.has_value 'ollama_url'; then
    OLLAMA_URL=$(bashio::config 'ollama_url')
fi

OLLAMA_MODEL="llama3"
if bashio::config.has_value 'ollama_model'; then
    OLLAMA_MODEL=$(bashio::config 'ollama_model')
fi

CLAUDE_API_KEY=""
if bashio::config.has_value 'claude_api_key'; then
    CLAUDE_API_KEY=$(bashio::config 'claude_api_key')
fi

CLAUDE_MODEL="claude-3-5-haiku-20241022"
if bashio::config.has_value 'claude_model'; then
    CLAUDE_MODEL=$(bashio::config 'claude_model')
fi

export GEMINI_API_KEY GEMINI_MODEL DEBUG AI_PROVIDER OLLAMA_URL OLLAMA_MODEL CLAUDE_API_KEY CLAUDE_MODEL

# Data directory for SQLite DB and images
export DATA_DIR="/data"
mkdir -p "${DATA_DIR}/images/products" "${DATA_DIR}/images/recipes"

bashio::log.info "Database: ${DATA_DIR}/storage.db"

exec python3 /app/main.py
